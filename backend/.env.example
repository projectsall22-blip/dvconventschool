PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/dv_convent_db?retryWrites=true&w=majority

# JWT — use a strong 64+ char random string
JWT_SECRET=your_super_secret_jwt_key_here_min_64_chars

# Token expiry
JWT_EXPIRE=7d

# Allowed frontend origins (your Vercel URL)
ALLOWED_ORIGINS=https://your-app.vercel.app
